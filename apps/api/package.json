{
  "name": "@maidongxi/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/lambda.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/lambda.mjs --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "dev": "node --import tsx --watch src/local.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.654.0",
    "@aws-sdk/client-translate": "^3.654.0",
    "@aws-sdk/lib-dynamodb": "^3.654.0",
    "@hono/node-server": "^1.13.1",
    "@maidongxi/shared": "*",
    "hono": "^4.6.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.143",
    "@types/node": "^20.16.5",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
